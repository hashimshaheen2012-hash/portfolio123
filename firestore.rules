rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Fields: title, description, image, tags, order, createdAt
    //
    // Collection: inquiries
    // Fields: name, email, message, status, createdAt
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "hashimshaheen2012@gmail.com" && request.auth.token.email_verified == true);
    }

    match /projects/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /inquiries/{id} {
      allow read: if isAdmin();
      allow create: if true; // Allow anyone to send a message
      allow update, delete: if isAdmin();
    }
  }
}
